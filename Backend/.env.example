# Application
APP_NAME=MyApp
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=myapp

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Logging
LOG_LEVEL=DEBUG

# === 業務設定 ===

# 台股開盤檢查：回溯補抓天數
TWSE_OPEN_CHECK_BACKFILL_DAYS=5

# 三大法人買賣金額（上市）：回溯補抓天數
TWSE_INSTITUTIONAL_BACKFILL_DAYS=5

# 三大法人買賣金額（上櫃）：回溯補抓天數
TPEX_INSTITUTIONAL_BACKFILL_DAYS=5

# 融資融券餘額：回溯補抓天數
MARGIN_TRADING_BACKFILL_DAYS=5

# 台指期未平倉：回溯補抓天數
FUTURES_OI_BACKFILL_DAYS=5

# 期貨三大法人未平倉：回溯補抓天數
FUTURES_INSTITUTIONAL_BACKFILL_DAYS=5

# FinMind API
FINMIND_API_TOKEN=your_finmind_token_here
